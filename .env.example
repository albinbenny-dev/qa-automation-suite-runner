# ════════════════════════════════════════════════════════════════════════════
# QA Automation Suite Runner — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is already in .gitignore.
# ════════════════════════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# ── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── App URL (sent to OpenRouter as HTTP-Referer) ─────────────────────────────
APP_URL=http://localhost:3000

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=file:/data/qa-infinity.db

# ── Database credentials (used by docker-compose for Postgres) ───────────────
POSTGRES_USER=qauser
POSTGRES_DB=qa_infinity
POSTGRES_PASSWORD=your-postgres-password-here

# ── Redis / BullMQ ───────────────────────────────────────────────────────────
REDIS_PASSWORD=your-redis-password-here
REDIS_URL=redis://:your-redis-password-here@qaasr-redis:6379

# ── JWT Auth ─────────────────────────────────────────────────────────────────
# Generate with: https://www.uuidgenerator.net/version4 (paste 2-3 UUIDs together)
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=8h

# ════════════════════════════════════════════════════════════════════════════
# AI / LLM PROVIDER  — choose ONE of the two options below
# Set LLM_PROVIDER to either "openrouter" or "anthropic"
# ════════════════════════════════════════════════════════════════════════════
LLM_PROVIDER=openrouter

# ── Option A: OpenRouter (recommended — works with your OpenRouter key) ───────
# Get your key at: https://openrouter.ai/keys
# Browse Claude models at: https://openrouter.ai/models?q=anthropic
OPENROUTER_API_KEY=your-openrouter-api-key-here
# Claude Sonnet 4 on OpenRouter — check https://openrouter.ai/models for exact name
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# ── Option B: Direct Anthropic API ───────────────────────────────────────────
# Only needed if LLM_PROVIDER=anthropic
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Jira Integration (Writer Agent) ─────────────────────────────────────────
JIRA_HOST=https://your-org.atlassian.net/
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token-here

# ── Email / SMTP (Reports Agent) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=QA Automation Suite Runner <no-reply@example.com>

# ── Security ─────────────────────────────────────────────────────────────────
# Shared secret between API and runner — generate with: openssl rand -hex 32
RUNNER_SECRET=your-runner-secret-here
# Set to "true" ONLY when onboarding new users, then set back to "false"
OPEN_REGISTRATION=false

# ── Docker runner ────────────────────────────────────────────────────────────
RUNNER_CONTAINER_NAME=qaasr-runner
PLAYWRIGHT_WORKERS=2

# ── Runner scaling ────────────────────────────────────────────────────────────
# RUNNER_CONCURRENCY: number of parallel test slots (Xvfb displays) per runner
# container. Each slot uses roughly 400-700 MB RAM under load. Default: 4.
RUNNER_CONCURRENCY=4

# RUNNER_REPLICAS: number of runner containers. When > 1, run gen-compose-override.sh
# to generate docker-compose.override.yml which wires up multiple runners behind nginx.
# Total parallel capacity = RUNNER_REPLICAS * RUNNER_CONCURRENCY.
# Default: 1 (single container, no nginx LB needed).
RUNNER_REPLICAS=1

# RUNNER_URL: override the runner endpoint the API calls. Leave blank for default.
# When RUNNER_REPLICAS=1 this stays as the direct container URL.
# When RUNNER_REPLICAS>1, gen-compose-override.sh sets this to the nginx upstream.
RUNNER_URL=
# VNC password for noVNC live-view (defaults to first 8 chars of RUNNER_SECRET).
# VNC RFB auth is capped at 8 characters — longer values are silently truncated.
# Set explicitly to a short password if you want a distinct VNC credential.
VNC_PASSWORD=

# ── Runner extra_hosts ────────────────────────────────────────────────────────
# To add internal hostnames that Docker cannot resolve, create a
# docker-compose.override.yml alongside docker-compose.yml:
#
#   services:
#     qaasr-runner:
#       extra_hosts:
#         - "my-internal-host.corp.local:10.0.0.1"
#
# This keeps site-specific IPs out of the committed compose file.

# ── F10 NOTE: EnvConfig passwords ────────────────────────────────────────────
# Environment configuration passwords (stored per-project in the DB) are
# currently plaintext. To encrypt them at rest, set ENV_ENCRYPTION_KEY to a
# 32-byte hex secret and update packages/api/src/routes/projects.ts to
# encrypt on write / decrypt on read using Node's built-in crypto.createCipheriv.
# This requires a migration to re-encrypt existing rows.
# ENV_ENCRYPTION_KEY=

# ── File size limits ─────────────────────────────────────────────────────────
MAX_UPLOAD_BYTES=52428800

# ── Data retention ───────────────────────────────────────────────────────────
RETENTION_RUNRESULT_DAYS=90
RETENTION_RUN_DAYS=180
RETENTION_HEAL_DAYS=30
RETENTION_LLMCALL_DAYS=90
RETENTION_ARTIFACTS_DAYS=30
RETENTION_VIDEO_DAYS=30
RETENTION_TRACE_DAYS=14
RETENTION_SCREENSHOT_DAYS=30
MAX_RUNS_PER_PROJECT=500
